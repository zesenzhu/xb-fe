# 默认仅通过 HTTP（80 端口）监听公网 IP 访问
:80 {
    # 1. 转发所有以 /api/ 开头的请求到后端 NestJS 服务（开发/生产默认映射在 8081）
    reverse_proxy /api/* 127.0.0.1:8081

    # 2. 转发所有其他页面请求到前端 Next.js standalone 服务（运行在 8080 端口）
    reverse_proxy * 127.0.0.1:8080
}

# 💡 以后绑定域名时，只需在服务器上把上面的第一行 ':80' 修改为你的域名：
# yourdomain.com {
#     ...
# }
# 之后重启/重载 Caddy 容器即可自动获取并配置 HTTPS 证书
